{
    "name": "whatsapp-server",
    "version": "1.0.0",
    "main": "index.js",
    "description": "WhatsApp Management Server",
    "author": "Antigravity",
    "scripts": {
        "start": "electron .",
        "postinstall": "electron-rebuild",
        "build": "electron-builder --win --dir"
    },
    "build": {
        "appId": "com.zapmax.server",
        "productName": "ZapMax Server",
        "electronVersion": "28.3.3",
        "asar": false,
        "win": {
            "target": "dir",
            "icon": "icon.png"
        },
        "directories": {
            "output": "../../dist/server"
        },
        "extraResources": [
            {
                "from": "icon.png",
                "to": "icon.png"
            }
        ]
    },
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "express": "^4.18.2",
        "groq-sdk": "^0.37.0",
        "jsonwebtoken": "^9.0.2",
        "multer": "^2.1.0",
        "puppeteer": "^24.40.0",
        "qrcode-terminal": "^0.12.0",
        "socket.io": "^4.7.2",
        "sqlite3": "^5.1.7",
        "whatsapp-web.js": "^1.23.0"
    },
    "devDependencies": {
        "@electron/rebuild": "^3.7.2",
        "electron": "28.3.3",
        "electron-builder": "^24.13.3"
    }
}
